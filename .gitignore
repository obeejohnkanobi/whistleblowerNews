# Build outputs (generated every build; can be safely re-created)
bin/
obj/

# NuGet packages folder (restored from package references)
packages/

# Rider / IntelliJ IDE metadata (local machine settings)
.idea/
riderModule.iml

# ReSharper caches (local analysis cache, safe to regenerate)
_ReSharper.Caches/

# Visual Studio / .NET local settings and cache
.vs/

# User-specific settings (each developer has their own)
*.user
*.suo
*.userosscache
*.sln.docstates

# Build logs and intermediate files
*.log

# OS junk files
Thumbs.db
Desktop.ini
.DS_Store

# Publish and profiling outputs (generated by tooling)
publish/
*.coverage
*.coveragexml
*.dotCover

# Local SQLite databases
*.db
*.db-shm
*.db-wal
