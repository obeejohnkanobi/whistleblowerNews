@model WhistleblowerNews.Web.Models.Comments.EditorCommentListViewModel
@{
    ViewData["Title"] = "All Comments";
}

<div class="page-header">
    <div>
        <h2>All Comments</h2>
        <p class="text-muted">Filter by username or article title.</p>
    </div>
    <form method="get" class="filter-bar">
        <label class="form-label" for="filter-username">Username</label>
        <input id="filter-username" class="form-control" type="text" name="username" value="@Model.Username" placeholder="Username" />
        <label class="form-label" for="filter-article">Article title</label>
        <input id="filter-article" class="form-control" type="text" name="articleTitle" value="@Model.ArticleTitle" placeholder="Article title" />
        <button type="submit" class="btn btn-sm btn-outline-primary">Filter</button>
    </form>
</div>

<div class="danger-zone">
    <div class="danger-title">Danger zone</div>
    <p>Deleting comments is permanent. Use edit when possible.</p>
</div>

@if (!Model.Comments.Any())
{
    <div class="card">
        <p>No comments match your filter.</p>
    </div>
}
else
{
    <div class="card">
        <table class="table">
            <thead>
            <tr>
                <th>Article</th>
                <th>User</th>
                <th>Content</th>
                <th>Created</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var comment in Model.Comments)
            {
                <tr>
                    <td>@comment.ArticleTitle</td>
                    <td>@comment.Username</td>
                    <td class="comment-body">@comment.Content</td>
                    <td>@comment.CreatedAt.ToString("u")</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@comment.Id">Edit</a>
                        <form asp-action="Delete" asp-route-id="@comment.Id" method="post" class="d-inline" data-confirm="Delete this comment?">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
