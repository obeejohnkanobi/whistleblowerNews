@model WhistleblowerNews.Web.Models.Comments.CommentFormViewModel
@{
    ViewData["Title"] = "Add Comment";
}

<h2>Add Comment</h2>

<p class="text-muted">Your comment will be visible publicly under the article.</p>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="articleId" value="@ViewData["ArticleId"]" />

    <div class="mb-3">
        <label asp-for="Content" class="form-label"></label>
        <textarea asp-for="Content" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Content" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Submit</button>
</form>
