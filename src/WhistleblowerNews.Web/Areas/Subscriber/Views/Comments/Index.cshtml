@model WhistleblowerNews.Web.Models.Comments.CommentListViewModel
@{
    ViewData["Title"] = "My Comments";
}

<div class="page-header">
    <div>
        <h2>My Comments</h2>
        <p class="text-muted">Newest first. Filter by article if needed.</p>
    </div>
    <form method="get" class="filter-bar">
        <label class="form-label" for="article-filter">Article</label>
        <select id="article-filter" name="articleId" class="form-select" data-auto-submit>
            <option value="">All articles</option>
            @foreach (var id in Model.ArticleIds)
            {
                <option value="@id" selected="@(Model.SelectedArticleId == id ? "selected" : null)">Article @id</option>
            }
        </select>
    </form>
</div>

@if (!Model.Comments.Any())
{
    <div class="card">
        <p>No comments yet.</p>
    </div>
}
else
{
    <div class="card">
        <table class="table">
            <thead>
            <tr>
                <th>Article</th>
                <th>Content</th>
                <th>Created</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var comment in Model.Comments)
            {
                <tr>
                    <td>Article @comment.ArticleId</td>
                    <td>@comment.Content</td>
                    <td>@comment.CreatedAt.ToString("u")</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary"
                           asp-action="Edit"
                           asp-route-id="@comment.Id">Edit</a>
                        <form asp-action="Delete" asp-route-id="@comment.Id" method="post" class="d-inline" data-confirm="Delete this comment?">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
