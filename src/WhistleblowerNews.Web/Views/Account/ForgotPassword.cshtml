@model WhistleblowerNews.Web.Models.Account.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Reset password";
}

<h2>Reset your password</h2>
<p class="text-muted">Enter the email address for your account and we will send a reset link.</p>

<form asp-action="ForgotPassword" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" autocomplete="email" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Send reset link</button>
    <a class="btn btn-outline-secondary" asp-controller="Account" asp-action="Login">Back to login</a>
</form>
