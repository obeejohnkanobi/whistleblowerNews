@model WhistleblowerNews.Web.Models.Account.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<h2>Login</h2>

<form asp-action="Login" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ReturnUrl" />

    <div class="mb-3">
        <label asp-for="Username" class="form-label"></label>
        <input asp-for="Username" class="form-control" />
        <span asp-validation-for="Username" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label"></label>
        <input asp-for="Password" class="form-control" type="password" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Login</button>
    <a class="btn btn-outline-secondary" asp-controller="Account" asp-action="ForgotPassword">Forgot password</a>
</form>

<div class="mt-4">
    <span class="text-muted">Need an account?</span>
    <a class="btn btn-sm btn-outline-secondary" asp-controller="Account" asp-action="Register">Sign up</a>
</div>
