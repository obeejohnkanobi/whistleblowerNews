{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=whistleblowerNews.db"
  },

  "RateLimiting": {
    "ReporterToken": {
      "PermitLimit": 5,
      "WindowSeconds": 10
    },
    "ReportSubmit": {
      "PermitLimit": 3,
      "WindowSeconds": 60
    }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}
