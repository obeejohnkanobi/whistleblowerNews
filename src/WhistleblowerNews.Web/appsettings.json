{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=whistleblowerNews.db"
  },

  "Email": {
    "FilePath": "logs/dev-emails.log",
    "FromAddress": "no-reply@whistleblowernews.local"
  },

  "RateLimiting": {
    "ReporterToken": {
      "PermitLimit": 5,
      "WindowSeconds": 10
    },
    "ReportSubmit": {
      "PermitLimit": 3,
      "WindowSeconds": 60
    },
    "AuthLogin": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    },
    "AuthRegister": {
      "PermitLimit": 5,
      "WindowSeconds": 60
    }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}
