@whistleblowerNews_HostAddress = https://localhost:7080

### Login as editor (sets auth cookie)
POST {{whistleblowerNews_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "username": "editor",
  "password": "editor123"
}

### Login as writer (sets auth cookie)
POST {{whistleblowerNews_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "username": "writer",
  "password": "writer123"
}

### Login as subscriber (sets auth cookie)
POST {{whistleblowerNews_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "username": "subscriber",
  "password": "subscriber123"
}

### Login as investigator (sets auth cookie)
POST {{whistleblowerNews_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "username": "investigator",
  "password": "investigator123"
}

### Get all articles (public)
GET {{whistleblowerNews_HostAddress}}/api/articles
Accept: application/json

### Get single article (public)
GET {{whistleblowerNews_HostAddress}}/api/articles/1
Accept: application/json

### Create article (Writer)
POST {{whistleblowerNews_HostAddress}}/api/articles
# Cookie: WhistleblowerNews.Auth=YOUR_COOKIE
Content-Type: application/json

{
  "title": "New article",
  "content": "Article content"
}

### Update article (Writer owner or Editor)
PUT {{whistleblowerNews_HostAddress}}/api/articles/1
# Cookie: WhistleblowerNews.Auth=YOUR_COOKIE
Content-Type: application/json

{
  "title": "Updated title",
  "content": "Updated content"
}

### Delete article (Writer owner or Editor)
DELETE {{whistleblowerNews_HostAddress}}/api/articles/1
# Cookie: WhistleblowerNews.Auth=YOUR_COOKIE

### Get comments for article (public)
GET {{whistleblowerNews_HostAddress}}/api/articles/1/comments
Accept: application/json

### Create comment (Subscriber)
POST {{whistleblowerNews_HostAddress}}/api/articles/1/comments
# Cookie: WhistleblowerNews.Auth=YOUR_COOKIE
Content-Type: application/json

{
  "content": "Nice article"
}

### Update comment (Subscriber owner or Editor)
PUT {{whistleblowerNews_HostAddress}}/api/comments/1
# Cookie: WhistleblowerNews.Auth=YOUR_COOKIE
Content-Type: application/json

{
  "content": "Updated comment"
}

### Delete comment (Subscriber owner or Editor)
DELETE {{whistleblowerNews_HostAddress}}/api/comments/1
# Cookie: WhistleblowerNews.Auth=YOUR_COOKIE

### Delete comment on own article (Writer)
DELETE {{whistleblowerNews_HostAddress}}/api/articles/1/comments/1
# Cookie: WhistleblowerNews.Auth=YOUR_COOKIE

### Create report (anonymous)
POST {{whistleblowerNews_HostAddress}}/api/reports
Content-Type: application/json

{
  "title": "Unsafe behavior",
  "description": "Details of the issue"
}

### Get report status (anonymous with token header)
GET {{whistleblowerNews_HostAddress}}/api/reports/YOUR_CASE_ID
X-Reporter-Token: YOUR_REPORTER_TOKEN
Accept: application/json

### Investigator request more info
POST {{whistleblowerNews_HostAddress}}/api/reports/YOUR_CASE_ID/request-info
# Cookie: WhistleblowerNews.Auth=YOUR_COOKIE
Content-Type: application/json

{
  "content": "Please provide more details"
}

### Update report status (Investigator or Editor)
PATCH {{whistleblowerNews_HostAddress}}/api/reports/YOUR_CASE_ID/status
# Cookie: WhistleblowerNews.Auth=YOUR_COOKIE
Content-Type: application/json

{
  "status": "Closed"
}
