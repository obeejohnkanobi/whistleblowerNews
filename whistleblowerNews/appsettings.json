{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=whistleblowerNews.db"
  },

  "Jwt": {
    "Issuer": "whistleblowerNews",
    "Audience": "whistleblowerNews",
    "SigningKey": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS"
  },

  "RateLimiting": {
    "ReporterToken": {
      "PermitLimit": 5,
      "WindowSeconds": 10
    },
    "ReportSubmit": {
      "PermitLimit": 3,
      "WindowSeconds": 60
    }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}
